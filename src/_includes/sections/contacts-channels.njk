<section class="contacts-channels" aria-label="Свържи се с нас">
  <div class="container-custom">
    <div class="contacts-channels__inner">

      <div class="contacts-channels__panel">

        <ul class="contacts-lines" aria-label="Телефон и имейл">

          <li>
            <a class="contacts-line" href="tel:{{ site.contact.phone }}">
              <span class="contacts-line__label">Телефон</span>
              <span class="contacts-line__value">+359 89 290 7007</span>
            </a>
          </li>

          <li>
            <a class="contacts-line" href="mailto:{{ site.contact.email }}">
              <span class="contacts-line__label">Имейл</span>
              <span class="contacts-line__value">{{ site.contact.email }}</span>
            </a>
          </li>

        </ul>

        <nav class="contacts-socials" aria-label="Социални мрежи">
          <a class="contacts-social contacts-social--instagram" href="{{ site.social.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <defs>
                <linearGradient id="cc-ig" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%"   stop-color="#FEDA77"/>
                  <stop offset="30%"  stop-color="#F58529"/>
                  <stop offset="60%"  stop-color="#DD2A7B"/>
                  <stop offset="100%" stop-color="#8134AF"/>
                </linearGradient>
              </defs>
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="url(#cc-ig)" stroke-width="2"/>
              <circle cx="12" cy="12" r="4" fill="none" stroke="url(#cc-ig)" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1" fill="url(#cc-ig)"/>
            </svg>
          </a>
          <a class="contacts-social contacts-social--tiktok" href="{{ site.social.tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
          </a>
          <a class="contacts-social contacts-social--facebook" href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a class="contacts-social contacts-social--whatsapp" href="{{ site.contact.whatsapp }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
          <a class="contacts-social contacts-social--viber" href="{{ site.contact.viber }}" aria-label="Viber">
            <img src="/assets/images/viber1.png" alt="" width="24" height="24" aria-hidden="true">
          </a>
        </nav>

      </div><!-- /.contacts-channels__panel -->

      <div class="contacts-form-block">

        <form class="contacts-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
          <input type="hidden" name="access_key" value="{{ site.forms.web3formsKey }}">
          <input type="hidden" name="redirect" value="{{ site.forms.redirectUrl }}">
          <input type="checkbox" name="botcheck" class="contacts-form__honey" tabindex="-1" autocomplete="off" aria-hidden="true">

          <label class="contacts-field">
            <input class="contacts-field__input" type="text" name="name" required placeholder=" " autocomplete="name">
            <span class="contacts-field__label">Име и фамилия</span>
            <span class="contacts-field__line" aria-hidden="true"></span>
          </label>

          <label class="contacts-field">
            <input class="contacts-field__input" type="email" name="email" required placeholder=" " autocomplete="email">
            <span class="contacts-field__label">Имейл</span>
            <span class="contacts-field__line" aria-hidden="true"></span>
          </label>

          <label class="contacts-field contacts-field--area">
            <textarea class="contacts-field__input contacts-field__input--area" name="message" required placeholder=" " rows="4"></textarea>
            <span class="contacts-field__label">Съобщение</span>
            <span class="contacts-field__line" aria-hidden="true"></span>
          </label>

          <button type="submit" class="btn-primary contacts-form__submit">
            Изпрати съобщението
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
        </form>

      </div>

    </div>
  </div>
</section>
