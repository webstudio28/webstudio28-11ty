<section class="projects" id="projects" aria-label="Избрани проекти">
  <div class="container-custom">

    <div class="projects__head" data-reveal>
      <span class="eyebrow">Избрани проекти</span>
      <h2 class="section-title">Сайтове, които <span>работят за клиентите ни</span></h2>
      <p class="section-lead">Малък поглед към последните ни проекти — от малки фирми до бизнеси с национален обхват.</p>
    </div>

    <div class="projects__grid" data-reveal>
      {% for project in projects %}{% if loop.index <= 3 %}
        <a class="project-card" href="{{ project.link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ project.title }} — отвори сайта">
          <div class="project-card__media">
            <span class="project-card__tag"><span class="project-card__tag-dot"></span>{{ project.title }}</span>
            <img src="{{ project.thumbnail }}" alt="" loading="lazy" onerror="this.style.display='none';this.parentNode.querySelector('.project-card__media-fallback').style.display='grid'">
            <div class="project-card__media-fallback" style="display:none" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          </div>
          <div class="project-card__body">
            <h3 class="project-card__title">{{ project.title }}</h3>
            <p class="project-card__desc">{{ project.description }}</p>
            <span class="project-card__foot">
              Виж проекта
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      {% endif %}{% endfor %}

      {# Mobile-only end card — matches normal card dimensions #}
      <a class="project-card project-card--more" href="/projects/" aria-label="Виж всички проекти">
        <div class="project-card__media">
          <div class="project-card__media-fallback">
            <div class="project-card__media-fallback-circle">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
        <div class="project-card__body">
          <h3 class="project-card__title">Виж повече</h3>
          <p class="project-card__desc">Разгледай всички наши последни проекти и сайтове.</p>
        </div>
      </a>
    </div>

    <div class="projects__cta-row">
      <a href="/projects/" class="btn-primary">
        Виж всички проекти
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>
