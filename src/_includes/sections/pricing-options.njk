<section class="pricing-tiers" aria-label="Видове уебсайтове">
  <div class="container-custom">
    <div class="pricing-tiers__grid">
      {% for tier in pricingTiers %}
      <article class="pricing-tier" data-tier="{{ tier.slug }}">
        <span class="pricing-tier__ordinal" aria-hidden="true">{{ tier.ordinal }}</span>

        <header class="pricing-tier__head">
          <h2 class="pricing-tier__title">{{ tier.title }}</h2>
        </header>

        <ul class="pricing-tier__features" aria-label="Включено в {{ tier.title }}">
          {% for feature in tier.features %}
          <li class="pricing-tier__feature">{{ feature }}</li>
          {% endfor %}
        </ul>

        <span class="pricing-tier__bracket pricing-tier__bracket--tr" aria-hidden="true"></span>
        <span class="pricing-tier__bracket pricing-tier__bracket--bl" aria-hidden="true"></span>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
