{% set nav = site.nav %}
<header class="site-header">
  <div class="container-custom">
    <div class="site-header__surface js-header-surface">

      <a href="/" class="site-header__brand" aria-label="Web Studio 28 — Начало">
        <img src="/assets/images/webstudio28-logo2.png" alt="Web Studio 28">
      </a>

      <nav class="site-header__nav" aria-label="Основна навигация">
        {% for item in nav %}
          <a href="{{ item.url }}"{% if page.url == item.url %} class="is-active" aria-current="page"{% endif %}>{{ item.label }}</a>
        {% endfor %}
      </nav>

      <div class="site-header__end">
        <button type="button" class="site-header__cta" data-open-consult>
          Безплатна консултация
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </button>

        <button
          type="button"
          class="menu-toggle"
          id="menu-toggle"
          aria-label="Отвори меню"
          aria-expanded="false"
          aria-controls="menu-panel"
        >
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
        </button>
      </div>

    </div>
  </div>
</header>

<div id="menu-backdrop" class="menu-backdrop" aria-hidden="true" hidden></div>

<aside id="menu-panel" class="menu-panel" aria-hidden="true" hidden>
  <button type="button" class="menu-close" id="menu-close" aria-label="Затвори меню">&times;</button>

  <nav class="menu-nav" aria-label="Мобилна навигация">
    {% for item in nav %}
      <a href="{{ item.url }}" class="menu-link"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a>
    {% endfor %}
    <button type="button" class="menu-link menu-link--cta" data-open-consult>Безплатна консултация</button>
  </nav>
</aside>
