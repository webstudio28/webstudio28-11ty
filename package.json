{
  "name": "webstudio28-11ty",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "css:build": "postcss src/assets/css/main.css -o src/assets/css/main.bundle.css --no-map",
    "css:watch": "postcss src/assets/css/main.css -o src/assets/css/main.bundle.css --no-map --watch",
    "start": "npm-run-all --parallel css:watch eleventy:serve",
    "eleventy:serve": "eleventy --serve",
    "build": "npm-run-all css:build eleventy:build",
    "eleventy:build": "eleventy",
    "build:cpanel": "node scripts/deploy-cpanel.js",
    "deploy": "echo 'Use GitHub Actions instead'"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.0"
  }
}
