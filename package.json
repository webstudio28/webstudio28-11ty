{
  "name": "webstudio28-11ty",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "css:build": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/tailwind-compiled.css --minify",
    "css:watch": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/tailwind-compiled.css --watch",
    "start": "npm-run-all --parallel css:watch eleventy:serve",
    "eleventy:serve": "eleventy --serve",
    "build": "npm-run-all css:build eleventy:build",
    "eleventy:build": "eleventy",
    "build:cpanel": "node scripts/deploy-cpanel.js",
    "deploy": "echo 'Use GitHub Actions instead'"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.0"
  }
}
